# ── JMAP (email) ──────────────────────────────────────────────────────────
# Generate an API token at: Settings → Privacy & Security → Manage API tokens
# Grant it: Mail (read)
FASTMAIL_API_TOKEN=your_fastmail_api_token_here

# ── CalDAV (calendar) ─────────────────────────────────────────────────────
# Fastmail calendar is NOT available via JMAP yet — CalDAV is required.
# CalDAV uses your email address + an app password (NOT the API token above).
# Generate an app password at: Settings → Privacy & Security → Manage app passwords
FASTMAIL_USERNAME=you@fastmail.com
FASTMAIL_APP_PASSWORD=your_app_password_here

# ── General ───────────────────────────────────────────────────────────────
# Your local timezone (used to determine "today" for calendar events)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# How many unread emails to return (max)
MAX_EMAILS=10

# Cache TTL in seconds (avoids hammering the Fastmail API on every Glance refresh)
MAIL_CACHE_TTL=300
CAL_CACHE_TTL=300
