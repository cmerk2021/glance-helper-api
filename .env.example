# Required: your Fastmail API token
# Generate one at: https://app.fastmail.com/settings/security/tokens
FASTMAIL_API_TOKEN=your_fastmail_api_token_here

# Your local timezone (used to determine "today" for calendar events)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# How many unread emails to return (max)
MAX_EMAILS=10

# Cache TTL in seconds (avoids hammering the Fastmail API on every Glance refresh)
MAIL_CACHE_TTL=300
CAL_CACHE_TTL=300
